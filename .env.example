# Copy to `.env` in this folder (Vite). Values must match your Sanity project.
# Create a project at https://www.sanity.io/manage — same Project ID in `studio/.env`.
# Sanity organization: odouhRmKi · project id: 9guj7jch

# Defaults to 9guj7jch / production in code if unset (same project as `npm create sanity@latest -- --project 9guj7jch ...`).
VITE_SANITY_PROJECT_ID=9guj7jch
VITE_SANITY_DATASET=production
# Keep browser-exposed `VITE_*` values public-only.
# If the dataset is private on Vercel, set a server-side read token instead:
# SANITY_READ_TOKEN=
# For `npm run seed:sanity` only — Editor token; never expose this in client env.
SANITY_API_WRITE_TOKEN=

# Optional: Web3Forms — https://web3forms.com
# Server-side only via `/api/contact`; do not prefix with `VITE_`.
WEB3FORM_API_KEY=
