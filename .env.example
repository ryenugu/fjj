# Copy to `.env` in this folder (Vite). Values must match your Sanity project.
# Create a project at https://www.sanity.io/manage — same Project ID in `studio/.env`.
# Sanity organization: odouhRmKi · project id: 9guj7jch

# Defaults to 9guj7jch / production in code if unset (same project as `npm create sanity@latest -- --project 9guj7jch ...`).
VITE_SANITY_PROJECT_ID=9guj7jch
VITE_SANITY_DATASET=production
# If `production` is a public dataset, leave empty (fast CDN, no token).
# If private: create a Viewer token and add http://localhost:5173 (and prod URL) to
# Sanity → Project → API → CORS origins, then set ONE of:
# VITE_SANITY_READ_TOKEN=
# VITE_SANITY_API_KEY=
# For `npm run seed:sanity` only — Editor token; not bundled in the app.
SANITY_API_WRITE_TOKEN=

# Optional: Web3Forms — https://web3forms.com (use any one line; restart dev after changing)
WEB3FORM_API_KEY=
# VITE_WEB3FORM_API_KEY=
# VITE_WEB3FORMS_ACCESS_KEY=
